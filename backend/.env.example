# ========================================
# SI TERTIB - Backend Environment Variables
# ========================================
# Salin file ini menjadi .env lalu sesuaikan nilainya

# NODE ENVIRONMENT
# Options: development, production
NODE_ENV=development

# ========== DATABASE CONFIGURATION ==========
# Database Host
# Lokal: localhost
# Production (PlanetScale/Railway/Aiven): your-host.mysql.database.azure.com
DB_HOST=localhost

# Database Port (default MySQL: 3306)
DB_PORT=3306

# Database User
DB_USER=root

# Database Password (kosong untuk lokal tanpa password)
DB_PASSWORD=

# Database Name
DB_NAME=sitertib_db

# ========== SERVER CONFIGURATION ==========
# Express Server Port
# Lokal: 5000
# Production (Render): biasanya auto-assign, tapi tetap perlu di-set
PORT=5000

# ========== JWT CONFIGURATION ==========
# Secret Key untuk JSON Web Token
# PENTING: Ganti dengan string acak yang panjang (minimal 32 karakter)
# Generate di: https://randomkeygen.com/
# Development: bisa sederhana
# Production: HARUS kompleks dan random!
JWT_SECRET=your_jwt_secret_key_min_32_chars_here

# Token Expiration Time
# Format: 8h (8 hours), 1d (1 day), 7d (7 days)
JWT_EXPIRES_IN=8h

# ========== OPTIONAL: FRONTEND URL ==========
# Gunakan untuk CORS configuration di production
# Contoh: https://sitertib-frontend.vercel.app
FRONTEND_URL=http://localhost:5173
