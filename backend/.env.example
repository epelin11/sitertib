# Salin file ini menjadi .env lalu sesuaikan nilainya

# Konfigurasi Database MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=sitertib_db

# Port server Express
PORT=5000

# Secret untuk JSON Web Token (ganti dengan string acak yang panjang)
JWT_SECRET=ganti_dengan_secret_key_yang_sangat_rahasia

# Masa berlaku token login (contoh: 8h, 1d, 7d)
JWT_EXPIRES_IN=8h
