# Konfigurasi Server
PORT=5000

# Konfigurasi Database MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=sitertib_db

# Konfigurasi JWT (ganti dengan string acak yang panjang & rahasia)
JWT_SECRET=ganti_dengan_kunci_rahasia_anda_yang_panjang
JWT_EXPIRES_IN=8h

# Konfigurasi aturan persentase
# Jumlah maksimum "keluar kelas" yang dianggap 100% dalam satu hari
# (silakan sesuaikan dengan jumlah jam pelajaran/mapel per hari di sekolah anda)
MAX_KELUAR_PER_HARI=6

# URL frontend (untuk CORS)
FRONTEND_URL=http://localhost:5173
